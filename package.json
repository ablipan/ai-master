{
  "name": "ai-master",
  "displayName": "AI Master",
  "description": "Stop typing. Start directing. An AI-native development extension that elevates you from writing code to orchestrating agents.",
  "version": "0.1.1",
  "publisher": "ablipan",
  "license": "MIT",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#4338ca",
    "theme": "dark"
  },
  "homepage": "https://github.com/ablipan/ai-master",
  "bugs": {
    "url": "https://github.com/ablipan/ai-master/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ablipan/ai-master"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "productivity",
    "workflow",
    "agent-first",
    "ai-native"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiMaster.toggleLock",
        "title": "AI Master: Toggle Mode",
        "icon": "$(rocket)"
      },
      {
        "command": "aiMaster.unlock",
        "title": "AI Master: Switch to Manual Mode",
        "icon": "$(edit)"
      },
      {
        "command": "aiMaster.showStats",
        "title": "AI Master: Show Progress"
      },
      {
        "command": "aiMaster.resetDailyStats",
        "title": "AI Master: Reset Daily Progress"
      },
      {
        "command": "aiMaster.noop",
        "title": "AI Master: AI Mode Active"
      }
    ],
    "keybindings": [
      {
        "command": "aiMaster.unlock",
        "key": "ctrl+shift+u",
        "mac": "cmd+shift+u",
        "when": "aiMaster.locked"
      },
      {
        "command": "aiMaster.noop",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "aiMaster.locked && editorTextFocus && !aiMaster.whitelisted"
      },
      {
        "command": "aiMaster.noop",
        "key": "ctrl+x",
        "mac": "cmd+x",
        "when": "aiMaster.locked && editorTextFocus && !aiMaster.whitelisted"
      },
      {
        "command": "aiMaster.noop",
        "key": "backspace",
        "when": "aiMaster.locked && editorTextFocus && !aiMaster.whitelisted"
      },
      {
        "command": "aiMaster.noop",
        "key": "delete",
        "when": "aiMaster.locked && editorTextFocus && !aiMaster.whitelisted"
      },
      {
        "command": "aiMaster.noop",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "aiMaster.locked && editorTextFocus && !aiMaster.whitelisted"
      },
      {
        "command": "aiMaster.noop",
        "key": "enter",
        "when": "aiMaster.locked && editorTextFocus && !aiMaster.whitelisted && !suggestWidgetVisible && !renameInputVisible && !inQuickOpen && !findInputFocussed"
      },
      {
        "command": "aiMaster.noop",
        "key": "tab",
        "when": "aiMaster.locked && editorTextFocus && !aiMaster.whitelisted && !suggestWidgetVisible && !inSnippetMode"
      }
    ],
    "configuration": {
      "title": "AI Master",
      "properties": {
        "aiMaster.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI Master agent-first mode."
        },
        "aiMaster.unlockDurationSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "maximum": 600,
          "description": "Seconds of manual mode per switch (default: 60)."
        },
        "aiMaster.dailyUnlockLimit": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Max manual mode switches per day (0 = unlimited)."
        },
        "aiMaster.whitelistGlobs": {
          "type": "array",
          "default": [
            "**/.env*",
            "**/*.json",
            "**/*.yml",
            "**/*.yaml",
            "**/*.toml",
            "**/*.md",
            "**/*.txt",
            "**/Makefile",
            "**/Dockerfile",
            "**/.gitignore"
          ],
          "items": {
            "type": "string"
          },
          "description": "Glob patterns for files always editable by hand (config, docs, etc.)."
        },
        "aiMaster.showUnlockReason": {
          "type": "boolean",
          "default": false,
          "description": "Ask why you're switching to manual mode (tracked in progress)."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiMasterPanel",
          "title": "AI Master",
          "icon": "resources/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "aiMasterPanel": [
        {
          "type": "webview",
          "id": "aiMaster.statsView",
          "name": "Statistics"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs --production",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.1",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.2",
    "ovsx": "^0.10.10",
    "typescript": "^5.8.3"
  }
}
